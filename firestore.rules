rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: versions
    // Document ID: auto-generated
    // Fields:
    //   - documentId: string (required) - The unique identifier for the PDF document.
    //   - name: string (required) - The name given to this version.
    //   - annotations: list (required) - The list of annotations (edits) in this version.
    //   - createdAt: timestamp (required) - The timestamp when this version was created.
    //   - uid: string (required) - The user ID of the person who created this version.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ishijima@b-p.co.jp" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function isValidVersion(data) {
      return hasRequiredFields(['documentId', 'name', 'annotations', 'createdAt', 'uid']) &&
             hasOnlyAllowedFields(['documentId', 'name', 'annotations', 'createdAt', 'uid']) &&
             data.documentId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.annotations is list &&
             data.createdAt is timestamp &&
             data.uid is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /versions/{versionId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidVersion(request.resource.data) && (isOwner(request.resource.data.uid) || isAdmin());
      allow update: if false; // Versions are immutable
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
